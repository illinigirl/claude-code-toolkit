#!/usr/bin/env bash
# Pre-demo / post-setup check. Reproduces what an MCP client (e.g. Claude
# Desktop) does and verifies the server will actually run on THIS machine.
# GREEN = safe to demo. Portable: resolves its own location.
set -u
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CMD="$DIR/.venv/bin/{{PROJECT_NAME}}"
DATA="${{{ENV_PREFIX}}_DATA_DIR:-$HOME/.{{PROJECT_NAME}}}"
fail=0
ok(){ echo "  ✅ $1"; }
bad(){ echo "  ❌ $1"; fail=1; }

echo "── {{PROJECT_NAME}} preflight ──"

# 1. Not in a macOS-protected folder — an app like Claude Desktop can't read a
#    venv under Documents/Desktop/Downloads ("Operation not permitted").
case "$DIR" in
  "$HOME/Documents/"*|"$HOME/Desktop/"*|"$HOME/Downloads/"*)
    bad "repo is in a macOS-protected folder ($DIR) — move it (e.g. ~/dev) and re-run ./setup.sh";;
  *) ok "repo location is outside protected folders";;
esac

# 2. The exact command an MCP client launches exists + is executable.
[ -x "$CMD" ] && ok "launch command present" || bad "launch command missing — run ./setup.sh: $CMD"

# 3. Clean MCP stdio handshake (no PermissionError / fatal import). Uses a
#    THROWAWAY data dir so it never touches (or races) the real library.
if [ -x "$CMD" ]; then
  resp="$( ( printf '%s\n' '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2024-11-05","capabilities":{},"clientInfo":{"name":"preflight","version":"1"}}}'; sleep 1 ) | env {{ENV_PREFIX}}_DATA_DIR="$(mktemp -d)" "$CMD" 2>/tmp/{{PACKAGE}}_preflight_err.txt | head -c 400 )"
  if grep -qiE "PermissionError|Fatal Python error|not permitted" /tmp/{{PACKAGE}}_preflight_err.txt; then
    bad "server crashed on launch:"; sed 's/^/      /' /tmp/{{PACKAGE}}_preflight_err.txt | head -4
  elif echo "$resp" | grep -q '"serverInfo"'; then ok "MCP handshake clean (responds to initialize)"
  else bad "no valid MCP response; stderr:"; sed 's/^/      /' /tmp/{{PACKAGE}}_preflight_err.txt | head -4; fi
fi

# 4. Library has data so live tools return real output (not an empty demo).
sumline="$(cd "$DIR" && PYTHONPATH=src {{ENV_PREFIX}}_DATA_DIR="$DATA" python3 -m {{PACKAGE}}.cli summary 2>/dev/null | head -1)"
case "$sumline" in
  0\ *|"") bad "library looks EMPTY at $DATA ($sumline) — seed/add records before demoing";;
  *) ok "library has data ($sumline) — dir: $DATA";;
esac

echo "───────────────────────────"
[ "$fail" = 0 ] && echo "GREEN — safe to demo" || echo "RED — fix above first"
exit $fail
