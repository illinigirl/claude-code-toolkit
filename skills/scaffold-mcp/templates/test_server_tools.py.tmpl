"""Integration tests for the MCP tool layer — the surface a reviewer actually
drives. The pure logic is covered in test_core; this pins the *tool contract*:
the happy-path round-trip, that an add flows through to the summary, the export,
and error paths. Tools are called in-process (they're plain functions) against a
sandboxed data dir, so no transport/runtime is needed. Skips if the MCP SDK
isn't installed (the pure-core tests don't need it).
"""

import pytest

pytest.importorskip("mcp")  # tool layer needs the MCP SDK; pure-core tests don't


@pytest.fixture
def srv(tmp_path, monkeypatch):
    monkeypatch.setenv("{{ENV_PREFIX}}_DATA_DIR", str(tmp_path))
    import {{PACKAGE}}.server as server
    return server


def test_list_and_summarize_seed(srv):
    listed = srv.list_{{DOMAIN_PLURAL}}()
    assert listed["count"] == 5
    s = srv.summarize_{{DOMAIN_PLURAL}}()
    assert s["count"] == 5
    assert s["total"] == 19
    assert s["by_category"]["alpha"]["total"] == 8


def test_add_then_retrievable_and_counted(srv):
    res = srv.add_{{DOMAIN}}(label="New {{DOMAIN_TITLE}}", value=4, category="alpha")
    assert res["added"] is True
    rid = res["{{DOMAIN}}_id"]
    assert srv.get_{{DOMAIN}}(rid)["label"] == "New {{DOMAIN_TITLE}}"
    # the added record flows into the summary — cross-session persistence
    assert srv.summarize_{{DOMAIN_PLURAL}}()["count"] == 6


def test_export_markdown_round_trip(srv):
    exp = srv.export_report()
    assert exp["format"] == "markdown"
    assert "{{PROJECT_NAME}}" in exp["content"]
    assert "| Category |" in exp["content"]


def test_export_text_is_plain(srv):
    exp = srv.export_report(format="text")
    assert exp["format"] == "text"
    assert "|" not in exp["content"]
    assert "#" not in exp["content"]


def test_filter_narrows_results(srv):
    assert srv.list_{{DOMAIN_PLURAL}}(category="alpha")["count"] == 2


def test_error_path_unknown_id(srv):
    assert "error" in srv.get_{{DOMAIN}}("does-not-exist")
